DATABASE_URL=
SESSION_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Required in every mode. Accepts either the server URL or a URL ending in /api/v1.
HEADSCALE_API_URL=
HEADSCALE_API_KEY=

# Optional deployment subpath, for example /panel. Leave empty for root deployment.
HEADPANEL_BASE_PATH=

# Optional host control. Keep false for a remote/API-only Headscale instance.
HEADSCALE_HOST_CONTROL=false
HEADSCALE_CONFIG_PATH=
HEADSCALE_BIN=
SYSTEMCTL_BIN=
